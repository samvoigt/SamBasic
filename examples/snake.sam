' =============================================
'   SNAKE
'   Use arrow keys or WASD to move
'   Eat food (*) to grow and score points
'   Don't hit the walls or yourself!
' =============================================

' ---- Food placement function ----
FUNCTION placeFood
  GLOBAL snakeX@, snakeY@, foodX#, foodY#
  overlap? = YES
  WHILE overlap?
    foodX# = 2 + RANDOM# 77
    foodY# = 3 + RANDOM# 21
    overlap? = NO
    FOR i# FROM 1 TO LENGTH# snakeX@
      IF snakeX@[i#] = foodX# AND snakeY@[i#] = foodY# THEN
        overlap? = YES
        BREAK
      END IF
    END FOR
  END WHILE
  SETCOLOR LIGHTRED&
  PRINTAT foodY#, foodX#, "*"
END FUNCTION

' ---- Draw border ----
SETCOLOR DARKGRAY&
FOR c# FROM 1 TO 80
  PRINTAT 2, c#, "-"
  PRINTAT 25, c#, "-"
END FOR
FOR r# FROM 3 TO 24
  PRINTAT r#, 1, "|"
  PRINTAT r#, 80, "|"
END FOR
PRINTAT 2, 1, "+"
PRINTAT 2, 80, "+"
PRINTAT 25, 1, "+"
PRINTAT 25, 80, "+"

' ---- Title bar ----
SETCOLOR YELLOW&
PRINTAT 1, 1, "SNAKE"
SETCOLOR LIGHTGRAY&
PRINTAT 1, 10, "Score: 0"
SETCOLOR DARKGRAY&
PRINTAT 1, 62, "Arrows / WASD"

' ---- Initialize snake (length 3, going right) ----
snakeX@ = [38, 39, 40]
snakeY@ = [13, 13, 13]
SETCOLOR GREEN&
PRINTAT 13, 38, "o"
PRINTAT 13, 39, "o"
SETCOLOR LIGHTGREEN&
PRINTAT 13, 40, "O"

' ---- Game state ----
score# = 0
dx# = 1
dy# = 0
interval# = 150
alive? = YES
foodX# = 0
foodY# = 0

' ---- Wait for player ----
SETCOLOR WHITE&
PRINTAT 20, 27, "Press any key to start..."
k$ = ""
WHILE k$ = ""
  k$ = GETKEY$
END WHILE
PRINTAT 20, 27, "                          "

' ---- Place first food (after clearing message) ----
placeFood

' ---- Main Game Loop ----
lastMove# = RUNNINGTIME#
WHILE alive?
  k$ = GETKEY$

  ' Update direction immediately (prevent 180-degree reverse)
  IF k$ = "ArrowRight" OR k$ = "d" OR k$ = "D" THEN
    IF dx# <> -1 THEN
      dx# = 1
      dy# = 0
    END IF
  END IF
  IF k$ = "ArrowLeft" OR k$ = "a" OR k$ = "A" THEN
    IF dx# <> 1 THEN
      dx# = -1
      dy# = 0
    END IF
  END IF
  IF k$ = "ArrowUp" OR k$ = "w" OR k$ = "W" THEN
    IF dy# <> 1 THEN
      dx# = 0
      dy# = -1
    END IF
  END IF
  IF k$ = "ArrowDown" OR k$ = "s" OR k$ = "S" THEN
    IF dy# <> -1 THEN
      dx# = 0
      dy# = 1
    END IF
  END IF

  ' Only advance the snake when enough time has passed
  now# = RUNNINGTIME#
  IF now# - lastMove# < interval# THEN
    CONTINUE
  END IF
  lastMove# = now#

  ' Calculate new head position
  len# = LENGTH# snakeX@
  newX# = snakeX@[len#] + dx#
  newY# = snakeY@[len#] + dy#

  ' Wall collision
  IF newX# < 2 OR newX# > 79 OR newY# < 3 OR newY# > 24 THEN
    alive? = NO
    BREAK
  END IF

  ' Self collision
  FOR i# FROM 1 TO len#
    IF snakeX@[i#] = newX# AND snakeY@[i#] = newY# THEN
      alive? = NO
      BREAK
    END IF
  END FOR
  IF NOT alive? THEN
    BREAK
  END IF

  ' Check if eating food
  ate? = NO
  IF newX# = foodX# AND newY# = foodY# THEN
    ate? = YES
    score# = score# + 10
    scoreStr$ = TOSTRING$ score#
    SETCOLOR LIGHTGRAY&
    PRINTAT 1, 10, "Score: " + scoreStr$
    PLAY "T200 O5 L16 E G", BACKGROUND YES, WAVE SQUARE
    ' Speed up
    interval# = interval# - 3
    IF interval# < 50 THEN
      interval# = 50
    END IF
  END IF

  ' Remove tail unless growing
  IF NOT ate? THEN
    PRINTAT snakeY@[1], snakeX@[1], " "
    REMOVE snakeX@ 1
    REMOVE snakeY@ 1
  END IF

  ' Turn old head into body
  len# = LENGTH# snakeX@
  SETCOLOR GREEN&
  PRINTAT snakeY@[len#], snakeX@[len#], "o"

  ' Add and draw new head
  APPEND snakeX@ newX#
  APPEND snakeY@ newY#
  SETCOLOR LIGHTGREEN&
  PRINTAT newY#, newX#, "O"

  ' Place new food if just ate
  IF ate? THEN
    placeFood
  END IF
END WHILE

' ---- Game Over ----
PLAY "T120 O3 L4 E- R8 L2 D-", BACKGROUND YES, WAVE TRIANGLE

' ---- Initialize high score arrays ----
hiScores@ = SIZE 10
hiNames@ = SIZE 10
FOR i# FROM 1 TO 10
  hiNames@[i#] = "---"
END FOR

' ---- Load scores from file ----
IF FILEEXISTS? "snake_scores.txt" THEN
  f# = OPEN# FILE "snake_scores.txt" MODE READ
  idx# = 0
  WHILE NOT (ENDOFFILE? f#)
    IF idx# = 10 THEN
      BREAK
    END IF
    idx# = idx# + 1
    scoreLine$ = READFILELINE$ FILE f#
    hiScores@[idx#] = TONUMBER# scoreLine$
    IF NOT (ENDOFFILE? f#) THEN
      hiNames@[idx#] = READFILELINE$ FILE f#
    END IF
  END WHILE
  CLOSE f#
END IF

' ---- Determine rank ----
rank# = 0
FOR i# FROM 1 TO 10
  IF score# > hiScores@[i#] THEN
    rank# = i#
    BREAK
  END IF
END FOR
' Check for empty slot if score didn't beat anyone
IF rank# = 0 THEN
  FOR i# FROM 1 TO 10
    IF hiScores@[i#] = 0 AND hiNames@[i#] = "---" THEN
      rank# = i#
      BREAK
    END IF
  END FOR
END IF

' ---- Shift entries down if ranked ----
IF rank# > 0 THEN
  i# = 10
  WHILE i# > rank#
    prev# = i# - 1
    hiScores@[i#] = hiScores@[prev#]
    hiNames@[i#] = hiNames@[prev#]
    i# = i# - 1
  END WHILE
END IF

' ---- Clear play area ----
blank$ = ""
FOR j# FROM 1 TO 78
  blank$ = blank$ + " "
END FOR
FOR r# FROM 3 TO 24
  PRINTAT r#, 2, blank$
END FOR

' ---- Display Game Over header ----
SETCOLOR RED&
PRINTAT 4, 35, "GAME OVER!"
scoreStr$ = TOSTRING$ score#
SETCOLOR YELLOW&
PRINTAT 5, 35, "Score: " + scoreStr$

' ---- Prompt for initials if ranked ----
IF rank# > 0 THEN
  SETCOLOR WHITE&
  MOVECURSOR 7, 28
  initials$ = INPUT$ "Enter your initials: "

  IF LENGTH# initials$ > 3 THEN
    initials$ = SUBSTRING$ initials$, 1, 3
  END IF
  initials$ = UPPERCASE$ initials$
  IF initials$ = "" THEN
    initials$ = "???"
  END IF

  hiScores@[rank#] = score#
  hiNames@[rank#] = initials$

  ' Save scores to file
  f# = OPEN# FILE "snake_scores.txt" MODE WRITE
  FOR i# FROM 1 TO 10
    temp$ = TOSTRING$ hiScores@[i#]
    WRITEFILELINE FILE f# LINE temp$
    WRITEFILELINE FILE f# LINE hiNames@[i#]
  END FOR
  CLOSE f#
END IF

' ---- Display high score table ----
SETCOLOR YELLOW&
PRINTAT 9, 35, "HIGH SCORES"

FOR i# FROM 1 TO 10
  row# = 10 + i#

  IF i# = rank# THEN
    SETCOLOR YELLOW&
  ELSE
    SETCOLOR LIGHTGRAY&
  END IF

  IF i# < 10 THEN
    rankStr$ = " " + TOSTRING$ i#
  ELSE
    rankStr$ = TOSTRING$ i#
  END IF

  PRINTAT row#, 25, rankStr$ + ".  " + hiNames@[i#]

  scoreStr$ = TOSTRING$ hiScores@[i#]
  scoreLen# = LENGTH# scoreStr$
  scoreCol# = 56 - scoreLen#
  PRINTAT row#, scoreCol#, scoreStr$
END FOR
