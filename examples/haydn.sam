' =============================================
'   Emperor Quartet - Joseph Haydn
'   String Quartet Op.76 No.3 in C major
'   II. Poco adagio, cantabile
'   Theme (Kaiserhymne) - Four voices
' =============================================

CLEARSCREEN
SETCOLOR YELLOW&
PRINT "  Emperor Quartet"
SETCOLOR LIGHTGRAY&
PRINT "  Joseph Haydn"
PRINT "  String Quartet Op.76 No.3"
PRINT "  II. Poco adagio, cantabile"
PRINT ""
SETCOLOR CYAN&
PRINT "  Now playing theme..."
PRINT "  (Kaiserhymne / Emperor's Hymn)"
PRINT ""

' Theme - Kaiserhymne in G major
' Violin I  = SINE     (upper harmony)
' Violin II = TRIANGLE (melody)
' Viola     = SQUARE   (inner voice)
' Cello     = SAWTOOTH (bass)
'
' Melody: G G B.A | G E F# G | A A C.B | A F# G A
'         B B D.C | B A G F# | E A F#.G | G...

PLAYPOLY ["T72 L4 O5 D D D. L8 C O4 L4 B G A B O5 C C E. L8 D L4 C O4 A B O5 C D D F#. L8 E L4 D C O4 B A G O5 C O4 A. L8 B L2 B. L4 R" WAVE SINE] ["T72 O4 L4 G G B. L8 A L4 G E F# G A A O5 L4 C. L8 O4 B L4 A F# G A B B O5 D. L8 C O4 L4 B A G F# E A F#. L8 G L2 G. L4 R" WAVE TRIANGLE] ["T72 O4 L4 D D D. L8 D L4 D C D D F# F# G. L8 G L4 E D D E G G B. L8 A L4 G F# E D C E D. L8 D L2 D. L4 R" WAVE SQUARE] ["T72 O3 L4 G G G. L8 D L4 G C D G D D C. L8 G L4 A D G D G G G. L8 A L4 G D E D C C D. L8 D L2 G. L4 R" WAVE SAWTOOTH]

PRINT ""
SETCOLOR GREEN&
PRINT "  Theme complete."
