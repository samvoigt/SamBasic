COLOR GREEN
PRINT "=== FizzBuzz ==="
COLOR LIGHTGRAY
PRINT ""

#count3 = 0
#count5 = 0

FOR #i GOESFROM 1 TO 30 WITHSTEP 1
  #count3 = #count3 + 1
  #count5 = #count5 + 1
  #fizz = 0
  #buzz = 0

  IF #count3 = 3 THEN
    #fizz = 1
    #count3 = 0
  ENDIF

  IF #count5 = 5 THEN
    #buzz = 1
    #count5 = 0
  ENDIF

  IF #fizz = 1 AND #buzz = 1 THEN
    COLOR YELLOW
    PRINT "FizzBuzz"
  ELSE
    IF #fizz = 1 THEN
      COLOR LIGHTCYAN
      PRINT "Fizz"
    ELSE
      IF #buzz = 1 THEN
        COLOR LIGHTMAGENTA
        PRINT "Buzz"
      ELSE
        COLOR LIGHTGRAY
        PRINT #i
      ENDIF
    ENDIF
  ENDIF
ENDFOR

COLOR LIGHTGRAY
PRINT ""
PRINT "Done!"
