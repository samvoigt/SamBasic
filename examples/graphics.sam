' =============================================
'   GRAPHICS DEMO
'   Demonstrates drawing primitives, buffering,
'   and sprites on the graphics canvas
' =============================================

' ---- Starfield with double buffering ----
BUFFERENABLED YES

' Draw a static background of stars
FOR i# FROM 1 TO 80
  starX# = RANDOM# 639
  starY# = RANDOM# 479
  SETCOLOR WHITE&
  DRAWPIXEL starX#, starY#
END FOR

' Draw some scenery
SETCOLOR DARKGRAY&
DRAWBOX 0, 400, 640, 480, YES

SETCOLOR GREEN&
DRAWBOX 0, 380, 640, 400, YES

' Mountains
SETCOLOR BROWN&
FOR peak# FROM 1 TO 5
  mx# = peak# * 120
  DRAWLINE mx#, 380, mx# - 80, 280
  DRAWLINE mx#, 380, mx# + 80, 280
  DRAWLINE mx# - 80, 280, mx# + 80, 280
END FOR

' Moon
SETCOLOR YELLOW&
DRAWCIRCLE 520, 80, 35, YES
SETCOLOR BLACK&
DRAWCIRCLE 535, 70, 30, YES

' Show the background
SHOWBUFFER

' ---- Animate a bouncing ball ----
ballX# = 100
ballY# = 200
dx# = 3
dy# = 2
radius# = 15

' Create a small sprite (8x8 diamond)
spriteRows@ = SIZE 8
FOR r# FROM 1 TO 8
  row@ = SIZE 8
  FOR c# FROM 1 TO 8
    dist# = ABS# r# - 4.5 + ABS# c# - 4.5
    IF dist# < 4 THEN
      row@[c#] = {.red# = 255, .green# = 85 + r# * 20, .blue# = 85}
    END IF
  END FOR
  spriteRows@[r#] = row@
END FOR
spriteId# = CREATESPRITE# spriteRows@

PRINTAT 1, 1, "GRAPHICS DEMO - press any key to quit"
SHOWBUFFER

' Main animation loop
WHILE GETKEY$ = ""
  CLEARBUFFER

  ' Redraw static background
  FOR i# FROM 1 TO 80
    starX# = RANDOM# 639
    starY# = RANDOM# 479
    SETCOLOR WHITE&
    DRAWPIXEL starX#, starY#
  END FOR

  SETCOLOR DARKGRAY&
  DRAWBOX 0, 400, 640, 480, YES
  SETCOLOR GREEN&
  DRAWBOX 0, 380, 640, 400, YES

  SETCOLOR BROWN&
  FOR peak# FROM 1 TO 5
    mx# = peak# * 120
    DRAWLINE mx#, 380, mx# - 80, 280
    DRAWLINE mx#, 380, mx# + 80, 280
    DRAWLINE mx# - 80, 280, mx# + 80, 280
  END FOR

  SETCOLOR YELLOW&
  DRAWCIRCLE 520, 80, 35, YES
  SETCOLOR BLACK&
  DRAWCIRCLE 535, 70, 30, YES

  ' Update ball position
  ballX# = ballX# + dx#
  ballY# = ballY# + dy#
  IF ballX# - radius# < 0 OR ballX# + radius# > 639 THEN
    dx# = 0 - dx#
  END IF
  IF ballY# - radius# < 0 OR ballY# + radius# > 370 THEN
    dy# = 0 - dy#
  END IF

  ' Draw the ball
  SETCOLOR LIGHTRED&
  DRAWCIRCLE ballX#, ballY#, radius#, YES
  SETCOLOR WHITE&
  DRAWCIRCLE ballX#, ballY#, radius#, NO

  ' Draw the sprite
  DRAWSPRITE SPRITE spriteId#, X ballX# + 30, Y ballY# - 20

  ' Draw some UI boxes
  SETCOLOR LIGHTCYAN&
  DRAWBOX 10, 10, 200, 30, NO

  PRINTAT 1, 2, "GRAPHICS DEMO"
  PRINTAT 2, 2, "Ball: " + TOSTRING$ ballX# + "," + TOSTRING$ ballY#

  SHOWBUFFER
  SLEEP 0.016
END WHILE
