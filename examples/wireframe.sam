' =============================================
'   3D Wireframe Demo
'   Spinning shapes with ground grid
' =============================================

CLEARSCREEN
SETCOLOR YELLOW&
PRINT "  3D Wireframe Demo"
SETCOLOR LIGHTGRAY&
PRINT "  Press any key to exit"
PRINT ""

' Ground grid (lines along X and Z axes)
SETCOLOR DARKGRAY&
FOR i# FROM -5 TO 5
  OBJECT3D# LINE, X1 i#, Y1 0, Z1 -5, X2 i#, Y2 0, Z2 5
  OBJECT3D# LINE, X1 -5, Y1 0, Z1 i#, X2 5, Y2 0, Z2 i#
END FOR

' Create shapes
SETCOLOR CYAN&
cube# = OBJECT3D# CUBE, SIZE 2
TRANSFORM3D TRANSLATE cube#, -3, 1.5, 0

SETCOLOR RED&
pyramid# = OBJECT3D# PYRAMID, BASE 2, HEIGHT 2.5
TRANSFORM3D TRANSLATE pyramid#, 3, 0, 0

SETCOLOR LIGHTGREEN&
sphere# = OBJECT3D# SPHERE, RADIUS 1, SEGMENTS 10
TRANSFORM3D TRANSLATE sphere#, 0, 2, 3

SETCOLOR YELLOW&
torus# = OBJECT3D# TORUS, RADIUS 1.5, TUBE 0.4, SEGMENTS 12, TUBESEGMENTS 6
TRANSFORM3D TRANSLATE torus#, 0, 1.5, -3

angle# = 0
BUFFERENABLED YES
WHILE GETKEY$ = ""
  CLEARBUFFER

  ' Rotate the cube and torus
  TRANSFORM3D ROTATE cube#, angle# * 0.5, angle#, 0
  TRANSFORM3D TRANSLATE cube#, -3, 1.5, 0

  TRANSFORM3D ROTATE torus#, angle# * 0.3, angle#, 0
  TRANSFORM3D TRANSLATE torus#, 0, 1.5, -3

  TRANSFORM3D ROTATE pyramid#, 0, angle# * 0.7, 0
  TRANSFORM3D TRANSLATE pyramid#, 3, 0, 0

  RENDER3D

  angle# = angle# + 2
  SHOWBUFFER
  SLEEP 0.016
END WHILE

SETCOLOR GREEN&
PRINT "Done!"
