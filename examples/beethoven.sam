' =============================================
'   Ode to Joy - Ludwig van Beethoven
'   Symphony No. 9, 4th Movement (1824)
'   Two-voice arrangement for SamBasic
' =============================================

SETCOLOR YELLOW&
PRINT "  Ode to Joy"
SETCOLOR LIGHTGRAY&
PRINT "  Ludwig van Beethoven"
PRINT "  Symphony No. 9, 4th Movement"
PRINT ""
SETCOLOR CYAN&
PRINT "  Now playing..."
PRINT ""

' ---- A section (first phrase) ----
' Melody: E E F G | G F E D | C C D E | E. D D
' Bass:   C   G   | E   G   | A   G   | C   G

PLAYPOLY ["T130 O4 L4 E E F G G F E D C C D E E. L8 D L2 D" WAVE SQUARE] ["T130 O3 L2 C G E G A G C G" WAVE TRIANGLE]

' ---- A section (second phrase) ----
' Melody: E E F G | G F E D | C C D E | D. C C
' Bass:   C   G   | E   G   | A   G   | G   C

PLAYPOLY ["T130 O4 L4 E E F G G F E D C C D E D. L8 C L2 C" WAVE SQUARE] ["T130 O3 L2 C G E G A G G C" WAVE TRIANGLE]

' ---- B section ----
' Melody: D D E C | D EF E C | D EF E D | C D  G
' Bass:   G   C   | G   C   | G   C   | G   G

PLAYPOLY ["T130 O4 L4 D D E C D L8 E F L4 E C D L8 E F L4 E D C D O3 L2 G" WAVE SQUARE] ["T130 O3 L2 G C G C G C G G" WAVE TRIANGLE]

' ---- A section (final phrase, slight variation) ----
' Melody: E E F G | G F E D | C C D E | D. C C
' Bass:   C   G   | E   G   | A   G   | G   C

PLAYPOLY ["T130 O4 L4 E E F G G F E D C C D E D. L8 C L2 C" WAVE SQUARE] ["T130 O3 L2 C G E G A G G C" WAVE TRIANGLE]

PRINT ""
SETCOLOR GREEN&
PRINT "  Done!"
